# .env.example
# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=aluminium_shop_prod

# Phoenix Configuration
SECRET_KEY_BASE=your_secret_key_base_here_generate_with_mix_phx_gen_secret
